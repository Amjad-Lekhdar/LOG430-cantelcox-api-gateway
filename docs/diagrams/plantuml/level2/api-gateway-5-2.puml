@startuml api-gateway-5-2
title api-gateway - Hexagonal Architecture cible

left to right direction
skinparam shadowing false
skinparam backgroundColor #FFFFFF
skinparam defaultFontName Arial
skinparam linetype ortho
skinparam rectangle {
  RoundCorner 8
}

rectangle "Clients
REST Client\nMonitoring\nOps Client" as Clients #FFF7ED
rectangle "Interface Adapters
Gateway API\nDiagnostics API" as Controllers #DBEAFE
hexagon "Gateway Model
RouteTarget\nProxyRequest\nTraceContext\nUpstreamResponse

Dependencies go inwards" as Domain #FFF2C6
rectangle "Ports
RouteRegistry\nUpstreamHttpPort\nMetricsPort" as Ports #F8FAFC
rectangle "Infrastructure Adapters
Settings Adapter\nHTTP Proxy Adapter\nPrometheus Adapter" as Adapters #DBEAFE
rectangle "Data Sources / External Systems
Configuration\nServices amont\nPrometheus" as Targets #F8FAFC

Clients --> Controllers
Controllers --> Domain
Domain --> Ports
Ports --> Adapters
Adapters --> Targets
@enduml
