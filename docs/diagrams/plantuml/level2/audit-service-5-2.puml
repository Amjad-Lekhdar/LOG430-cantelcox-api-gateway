@startuml audit-service-5-2
title audit-service - Hexagonal Architecture cible

left to right direction
skinparam shadowing false
skinparam backgroundColor #FFFFFF
skinparam defaultFontName Arial
skinparam linetype ortho
skinparam rectangle {
  RoundCorner 8
}

rectangle "Clients
REST Clients\nEvent Producer\nOps Client" as Clients #FFF7ED
rectangle "Interface Adapters
AuditController\nEventConsumer" as Controllers #DBEAFE
hexagon "Business Model
AuditEvent\nActor\nRiskSignal\nAppendOnlyLog

Dependencies go inwards" as Domain #FFF2C6
rectangle "Ports
AuditRepository\nFraudRulesPort\nAlertPort" as Ports #F8FAFC
rectangle "Infrastructure Adapters
PostgreSQL Adapter\nFraudRulesEngine\nAlertPublisher" as Adapters #DBEAFE
rectangle "Data Sources / External Systems
Audit DB\nFraud Rules\nOps Channel" as Targets #F8FAFC

Clients --> Controllers
Controllers --> Domain
Domain --> Ports
Ports --> Adapters
Adapters --> Targets
@enduml
