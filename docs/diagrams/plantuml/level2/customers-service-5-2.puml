@startuml customers-service-5-2
title customers-service - Hexagonal Architecture cible

left to right direction
skinparam shadowing false
skinparam backgroundColor #FFFFFF
skinparam defaultFontName Arial
skinparam linetype ortho
skinparam rectangle {
  RoundCorner 8
}

rectangle "Clients
REST Client\nProfile Flow\nConsent Flow" as Clients #FFF7ED
rectangle "Interface Adapters
CustomerController\nConsentController" as Controllers #DBEAFE
hexagon "Business Model
Customer\nContactInfo\nAddress\nConsent

Dependencies go inwards" as Domain #FFF2C6
rectangle "Ports
CustomerRepository\nIdentityPort\nAuditPort" as Ports #F8FAFC
rectangle "Infrastructure Adapters
PostgreSQL Adapter\nIdentityClient\nAuditClient" as Adapters #DBEAFE
rectangle "Data Sources / External Systems
Customers DB\nidentity-service\naudit-service" as Targets #F8FAFC

Clients --> Controllers
Controllers --> Domain
Domain --> Ports
Ports --> Adapters
Adapters --> Targets
@enduml
