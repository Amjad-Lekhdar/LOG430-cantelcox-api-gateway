@startdot customers-service-5-2
digraph G {
  graph [
    label="Whitebox customers-service - Architecture hexagonale",
    labelloc=t,
    fontsize=18,
    fontname="Arial",
    bgcolor="white",
    rankdir=LR,
    splines=ortho,
    nodesep=0.55,
    ranksep=0.75
  ];

  node [shape=box, style="rounded,filled", fontname="Arial", fontsize=11, color="#111827"];
  edge [fontname="Arial", fontsize=10, color="#A80036", arrowsize=0.75];

  Interface [label="Interface Layer", fillcolor="#FEF3C7"];
  Business [label="Business Layer", fillcolor="#DBEAFE"];
  Infra [label="Infrastructure Layer", fillcolor="#FECACA"];

  Gateway [label="API Gateway\nREST client", fillcolor="#FFF7ED"];
  CustomerApi [label="CustomerController\n/v1/customers/*", fillcolor="#DBEAFE"];

  UseCases [label="Application Services\nGetProfile\nUpdateProfile\nManageConsent", fillcolor="#E0F2FE"];
  Domain [
    label="Business Model\n\nCustomer\nContactInfo\nAddress\nConsent\n\nDependencies go inwards",
    shape=polygon,
    sides=6,
    style=filled,
    fillcolor="#FEF3C7",
    color="#B91C1C",
    width=3.1,
    height=2.1
  ];
  Ports [label="Ports\nCustomerRepository\nIdentityPort\nAuditPort", fillcolor="#F8FAFC"];

  Repo [label="CustomerRepository Adapter\nSQL", fillcolor="#DBEAFE"];
  Identity [label="IdentityClient\nHTTP REST", fillcolor="#DBEAFE"];
  Audit [label="AuditClient\nHTTP REST", fillcolor="#DBEAFE"];

  Db [label="Customers DB", shape=cylinder, fillcolor="#E0F2FE"];
  IdentitySvc [label="identity-service", fillcolor="#F8FAFC"];
  AuditSvc [label="audit-service", fillcolor="#F8FAFC"];

  { rank=same; Interface; Business; Infra; }
  Interface -> Business -> Infra [style=invis, weight=10];

  Gateway -> CustomerApi [label="gerer profil"];
  CustomerApi -> UseCases;
  UseCases -> Domain;
  UseCases -> Ports;
  Ports -> Repo [label="persiste profil"];
  Ports -> Identity [label="verifie identite"];
  Ports -> Audit [label="trace profil"];
  Repo -> Db;
  Identity -> IdentitySvc;
  Audit -> AuditSvc;
}
@enddot
