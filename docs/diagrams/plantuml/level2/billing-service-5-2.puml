@startuml billing-service-5-2
title billing-service - Hexagonal Architecture cible

left to right direction
skinparam shadowing false
skinparam backgroundColor #FFFFFF
skinparam defaultFontName Arial
skinparam linetype ortho
skinparam rectangle {
  RoundCorner 8
}

rectangle "Clients
REST Client\nPayment Provider\nUsage Producer" as Clients #FFF7ED
rectangle "Interface Adapters
BillingController\nPaymentWebhook" as Controllers #DBEAFE
hexagon "Business Model
BillingAccount\nUsageRecord\nInvoice\nPayment

Dependencies go inwards" as Domain #FFF2C6
rectangle "Ports
BillingRepository\nUsageProvider\nPaymentPort\nAuditPort" as Ports #F8FAFC
rectangle "Infrastructure Adapters
PostgreSQL Adapter\nUsage Adapter\nPaymentGateway\nAuditClient" as Adapters #DBEAFE
rectangle "Data Sources / External Systems
Billing DB\nUsage Source\nPayment Gateway\naudit-service" as Targets #F8FAFC

Clients --> Controllers
Controllers --> Domain
Domain --> Ports
Ports --> Adapters
Adapters --> Targets
@enduml
