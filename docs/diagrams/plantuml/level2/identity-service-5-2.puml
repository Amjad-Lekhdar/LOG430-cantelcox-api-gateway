@startuml identity-service-5-2
title identity-service - Hexagonal Architecture cible

left to right direction
skinparam shadowing false
skinparam backgroundColor #FFFFFF
skinparam defaultFontName Arial
skinparam linetype ortho
skinparam rectangle {
  RoundCorner 8
}

rectangle "Clients
REST Client\nAuth Flow\nAdmin Client" as Clients #FFF7ED
rectangle "Interface Adapters
UserController\nAuthController" as Controllers #DBEAFE
hexagon "Business Model
User\nIdentityProfile\nCredential\nMfaChallenge

Dependencies go inwards" as Domain #FFF2C6
rectangle "Ports
UserRepository\nMfaProvider\nAuditPort" as Ports #F8FAFC
rectangle "Infrastructure Adapters
PostgreSQL Adapter\nOTP/MFA Adapter\nAuditClient" as Adapters #DBEAFE
rectangle "Data Sources / External Systems
Identity DB\nOTP Provider\naudit-service" as Targets #F8FAFC

Clients --> Controllers
Controllers --> Domain
Domain --> Ports
Ports --> Adapters
Adapters --> Targets
@enduml
