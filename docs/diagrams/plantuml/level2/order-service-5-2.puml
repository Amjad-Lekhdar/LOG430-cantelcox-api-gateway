@startuml order-service-5-2
title order-service - Hexagonal Architecture cible

left to right direction
skinparam shadowing false
skinparam backgroundColor #FFFFFF
skinparam defaultFontName Arial
skinparam linetype ortho
skinparam rectangle {
  RoundCorner 8
}

rectangle "Clients
REST Client\nCheckout Flow\nBackoffice" as Clients #FFF7ED
rectangle "Interface Adapters
OrderController\nActivationRequest" as Controllers #DBEAFE
hexagon "Business Model
Order\nOrderItem\nOrderStatus\nIdempotencyKey

Dependencies go inwards" as Domain #FFF2C6
rectangle "Ports
OrderRepository\nCatalogPort\nLineActivationPort" as Ports #F8FAFC
rectangle "Infrastructure Adapters
PostgreSQL Adapter\nCatalogClient\nLineServiceClient" as Adapters #DBEAFE
rectangle "Data Sources / External Systems
Orders DB\ncatalog-service\nline-service" as Targets #F8FAFC

Clients --> Controllers
Controllers --> Domain
Domain --> Ports
Ports --> Adapters
Adapters --> Targets
@enduml
